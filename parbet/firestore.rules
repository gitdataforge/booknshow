rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // LEGACY ARCHITECTURE (PRESERVED STRICTLY)
    // =========================================================================

    // 1. site_assets Collection (The CMS Bridge)
    // Allows Main site to display banners while restricting edits to authenticated sellers
    match /site_assets/{assetId} {
      allow read: if true; 
      allow write: if request.auth != null;
    }

    // 2. listings Collection (P2P Tickets)
    // Public can view tickets; only the owner can modify their specific listing
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // 3. users & wallets Collections (Private Data)
    // Strict ID matching: Users can only see/edit their own profile and balance
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /wallets/{walletId} {
      allow read, write: if request.auth != null && request.auth.uid == walletId;
    }

    // 4. orders Collection (Transaction History)
    // Access restricted to the specific buyer or the seller involved in the transaction
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
    }

    // =========================================================================
    // NEW PRODUCTION ARCHITECTURE (100% SECURE ARTIFACT ROUTING)
    // =========================================================================
    
    // 5. Artifacts Architecture (Mandatory 6-Segment Pathing)
    match /artifacts/{appId} {
      
      // A. Public Data (Tickets, Feedback, Shared Marketplace)
      // Path: /artifacts/{appId}/public/data/{collectionName}/{docId}
      match /public/data/{collectionName}/{docId} {
        allow read: if true; // Public can view active listings and global events
        allow write: if request.auth != null; // Authenticated users can write feedback/tickets
      }
      
      // B. Private User Data (Orders, Wallet, Profile, Settings)
      // Path: /artifacts/{appId}/users/{userId}/{collectionName}/{docId}
      // Strict ID Matching: Prevents any user from reading another user's financial or order data
      match /users/{userId}/{collectionName}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // C. Deep Wildcard Fallback for Nested Private Documents (e.g., wallet/main)
      match /users/{userId}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // =========================================================================
    // SECURITY CATCH-ALL
    // =========================================================================
    // Default deny for any other collection to ensure "Secure by Default" posture
    match /{document=**} {
      allow read, write: if false;
    }
  }
}