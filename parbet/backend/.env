# ==========================================
# SECTION 1: CORE SERVER CONFIGURATION
# ==========================================
PORT=8080
NODE_ENV=production

# ==========================================
# SECTION 2: RESEND API GATEWAY
# ==========================================
RESEND_API_KEY=re_your_actual_api_key_here

# ==========================================
# SECTION 3: FIREBASE ADMIN IDENTITY
# ==========================================
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./firebaseServiceAccount.json
FIREBASE_PROJECT_ID=parbet-44902

# ==========================================
# SECTION 4: SECURITY & CORS ORIGINS
# ==========================================
# Allow requests from your buyer and seller sites
ALLOWED_ORIGIN_BUYER=https://booknshow.in
ALLOWED_ORIGIN_SELLER=https://sell-booknshow.in

# ==========================================
# SECTION 5: EMAIL IDENTITY SETTINGS
# ==========================================
EMAIL_FROM_NAME=booknshow
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# ==========================================
# SECTION 6: REDIRECT URI LOGIC
# ==========================================
# Redirects users back to the app after verification/reset
VERIFICATION_REDIRECT_URL=https://booknshow.in/profile
PASSWORD_RESET_REDIRECT_URL=https://booknshow.in/login

# ==========================================
# SECTION 7: RATE LIMITING PROTOCOLS
# ==========================================
MAX_REQUESTS_PER_WINDOW=100
WINDOW_SIZE_MS=900000

# ==========================================
# SECTION 8: LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info
DEBUG_ENABLED=false

# ==========================================
# SECTION 9: ARCHITECTURAL VERSIONING
# ==========================================
API_VERSION=v1
APP_IDENTITY=Booknshow_Secure_Vault

# ==========================================
# SECTION 10: ADVANCED SMTP FAILOVER (OPTIONAL)
# ==========================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=465